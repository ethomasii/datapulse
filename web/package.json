{
  "name": "eltpulse-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "export-elt-catalog": "python ../scripts/export-credentials-catalog.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "npx dotenv-cli -e .env.local -- prisma db push",
    "db:migrate": "npx dotenv-cli -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "npx dotenv-cli -e .env.local -- prisma migrate deploy",
    "db:studio": "npx dotenv-cli -e .env.local -- prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/client-sqs": "^3.758.0",
    "@anthropic-ai/sdk": "^0.80.0",
    "@clerk/nextjs": "^5.7.5",
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^14.2.35",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.4",
    "stripe": "^21.0.1",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
