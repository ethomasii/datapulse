// eltPulse — minimal SaaS schema (Clerk + Stripe + Neon)
// Extend with workspaces, pipelines, and run history as the product grows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Neon: use the non-pooled “direct” connection string. For local Postgres, set to the same value as `DATABASE_URL`.
  directUrl = env("DIRECT_URL")
}

enum PlanTier {
  free
  pro
  team
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
  incomplete_expired
  paused
}

/// Who runs pipeline ingestion for this account. Telemetry (runs, logs) is always stored in eltPulse either way.
enum ExecutionPlane {
  /// Customer-operated execution (optional self-hosted agent token, CI, or control-plane API reporting).
  customer_agent
  /// eltPulse-operated managed execution (SaaS default).
  eltpulse_managed
  /// Legacy label on older databases; treated as `eltpulse_managed` in app logic. Migrated away by SQL migrations.
  datapulse_managed
}

/// How this run’s telemetry was produced / who executed ingestion. Distinct from `triggeredBy` (schedule, webhook, etc.).
enum RunIngestionExecutor {
  unspecified
  customer_agent
  eltpulse_managed
  /// Legacy label on older databases; treated as `eltpulse_managed` in app logic.
  datapulse_managed
  /// Logged-in app or session API (`/api/elt/runs`) reporting without the self-hosted agent.
  customer_control_plane
}

/// Per-pipeline default for who executes new runs (hybrid: some managed, some on your gateway).
enum PipelineExecutionHost {
  /// Follow account/org execution plane (`User.executionPlane`) for managed vs customer.
  inherit
  /// Force eltPulse-managed workers for this pipeline’s new runs.
  eltpulse_managed
  /// Force self-hosted gateway resolution (tokens / routing) for this pipeline’s new runs.
  customer_gateway
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  imageUrl  String?
  /// Optional HTTPS URL — POST when a pipeline run finishes (success or failure). No warehouse secrets in payload.
  runsWebhookUrl String? @db.Text
  /// Secret token for the incoming webhook trigger endpoint (POST /api/webhooks/trigger/:token).
  incomingWebhookToken String? @unique @db.Text
  /// Optional account-wide gateway Bearer token (polls pending runs, reports back). Omit for API-only, org token, or named-connector-only flows.
  agentToken String? @unique @db.Text
  /// Preferred execution plane; does not require `agentToken` when set to `customer_agent` (CI / app can still report runs).
  executionPlane ExecutionPlane @default(eltpulse_managed) @map("execution_plane")
  /// Last successful `POST /api/agent/heartbeat` (customer connector) or internal managed touch — survives serverless restarts.
  agentLastSeenAt      DateTime? @map("agent_last_seen_at")
  agentLastSeenVersion String?   @map("agent_last_seen_version")
  agentLastSeenLabels  Json      @default("{}") @map("agent_last_seen_labels")
  /// `customer_agent` = your process with Bearer token; `eltpulse_managed` = eltPulse-operated worker (SaaS / dedicated).
  agentLastSeenSource  String?   @map("agent_last_seen_source")
  /// Set when user clicks "Dismiss" on the dashboard onboarding checklist.
  onboardingDismissedAt DateTime? @map("onboarding_dismissed_at")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription?
  eltPipelines EltPipeline[]
  githubConnection GithubConnection?
  eltPipelineRuns EltPipelineRun[]
  connections Connection[]
  eltMonitors EltMonitor[]

  /// Membership in a shared org (not the owner row — use `ownedOrganization`).
  organizationId String?       @map("organization_id")
  organization   Organization? @relation("OrganizationMembers", fields: [organizationId], references: [id], onDelete: SetNull)
  /// Org this user owns (billing + org-level gateway defaults). At most one.
  ownedOrganization Organization? @relation("OrganizationOwner")
  /// When set, unrouted runs (no pipeline default, no per-run override) pin to this named gateway. Distinct from legacy `agentToken`.
  defaultAgentTokenId String?     @unique @map("default_agent_token_id")
  defaultAgentToken    AgentToken? @relation("UserAccountDefaultGateway", fields: [defaultAgentTokenId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([defaultAgentTokenId])
  /// Named agent connectors (AWS, GCP, on-prem, etc.) — each has its own Bearer token and heartbeat.
  agentTokens AgentToken[]
}

/// Per-user agent API token (multiple connectors: one per cloud, on-prem, etc.).
model AgentToken {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// When set, token is shared by this Clerk-linked org (Pro/Team). `userId` is the org owner for billing FK.
  organizationId   String?   @map("organization_id")
  organization     Organization? @relation("OrgScopedAgentTokens", fields: [organizationId], references: [id], onDelete: SetNull)
  name             String
  token            String    @unique @db.Text
  /// Optional labels, e.g. `{ "cloud": "aws", "site": "on-prem-dc1" }` for your own routing — not secret.
  metadata         Json      @default("{}")
  lastSeenAt       DateTime? @map("last_seen_at")
  lastSeenVersion  String?   @map("last_seen_version")
  lastSeenLabels   Json      @default("{}") @map("last_seen_labels")
  lastSeenSource   String?   @map("last_seen_source")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  /// Runs pinned to this gateway only (null on run = any gateway may execute).
  targetedRuns            EltPipelineRun[]
  /// Pipelines whose new runs default to this gateway unless overridden.
  pipelinesDefaultGateway EltPipeline[]  @relation("PipelineDefaultGateway")
  /// User who selected this token as account-level default for unrouted runs (at most one).
  userAccountDefaultFor User? @relation("UserAccountDefaultGateway")
  /// Org that selected this token as workspace default for unrouted runs (at most one org row).
  organizationAsWorkspaceDefault Organization? @relation("OrganizationDefaultGateway")

  @@index([userId])
  @@index([organizationId])
  @@map("AgentToken")
}

/// Shared workspace: billing tier follows the owner’s subscription; org-scoped gateway uses `agentToken`.
model Organization {
  id          String   @id @default(cuid())
  name        String
  /// Clerk Organization id when using Clerk orgs — optional until wired.
  clerkOrgId  String?  @unique @map("clerk_org_id")
  ownerUserId String   @unique @map("owner_user_id")
  owner       User     @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  /// Bearer token for org-scoped gateways (same API as user `agentToken`).
  agentToken  String?  @unique @map("agent_token") @db.Text
  /// Named gateway default for unrouted runs when working in this org (Clerk org session).
  defaultAgentTokenId String?     @unique @map("default_agent_token_id")
  defaultAgentToken    AgentToken? @relation("OrganizationDefaultGateway", fields: [defaultAgentTokenId], references: [id], onDelete: SetNull)
  /// Optional floor for sensor checks (seconds). If set, overrides plan-tier default for this org (e.g. enterprise contract).
  sensorPollIntervalSecondsOverride Int? @map("sensor_poll_interval_seconds_override")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members User[] @relation("OrganizationMembers")
  orgScopedAgentTokens AgentToken[] @relation("OrgScopedAgentTokens")

  @@index([ownerUserId])
  @@index([defaultAgentTokenId])
  @@map("Organization")
}

/// Optional: per-customer GitHub OAuth (BYO org). Disabled when using managed repos under eltPulse’s org only.
model GithubConnection {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubUserId     String
  githubLogin      String
  accessTokenEnc   String   @db.Text
  scope            String?
  defaultRepoOwner String?
  defaultRepoName  String?
  defaultBranch    String?  @default("main")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

/// Named, reusable connection profile (source or destination). Referenced by monitors and pipelines (FK).
model Connection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Human-readable label, e.g. "prod-postgres" or "bigquery-warehouse"
  name        String
  /// "source" | "destination"
  connectionType String
  /// Connector key, e.g. "postgres", "bigquery", "snowflake", "github"
  connector   String
  /// Non-secret config blob (schema, project_id, account, etc.).
  config      Json     @default("{}")
  /// AES-256-GCM ciphertext of JSON `Record<envKey, secretValue>` (catalog keys only). Optional: agent / future managed runners.
  connectionSecretsEnc String? @map("connection_secrets_enc") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  eltMonitors EltMonitor[]
  pipelinesAsSource      EltPipeline[] @relation("PipelineSourceConnection")
  pipelinesAsDestination EltPipeline[] @relation("PipelineDestinationConnection")
}

/// eltPulse monitor — evaluated on the control plane and/or your gateway depending on `executionHost` + account plane.
model EltMonitor {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  pipelineId       String    @map("pipeline_id")
  pipeline         EltPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  type             String
  config           Json      @default("{}")
  connectionId     String?
  connection       Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  /// Hybrid: inherit account plane, force eltPulse cron, or force gateway-side evaluation only.
  executionHost    PipelineExecutionHost @default(inherit) @map("execution_host")
  lastCheckAt      DateTime?
  lastTriggeredAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([pipelineId])
  @@map("EltMonitor")
}

/// Generated ELT pipeline definitions stored in Neon. Execution is customer-operated (optional agent / API) or eltPulse-managed when enabled.
model EltPipeline {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  tool                String // "dlt" | "sling"
  enabled             Boolean  @default(true)
  sourceType          String
  destinationType     String
  description         String?
  groupName           String?
  sourceConfiguration Json     @default("{}")
  pipelineCode        String   @db.Text
  configYaml          String?  @db.Text
  /// eltPulse workspace manifest (scheduling, monitors, metadata). Stored as YAML text.
  workspaceYaml       String?  @map("workspace_yaml") @db.Text
  /// Optional: POST run events here for this pipeline only (overrides account default when set).
  runsWebhookUrl      String?  @db.Text
  /// New pending runs from triggers/API inherit this gateway unless a per-run override is set.
  defaultTargetAgentTokenId String?     @map("default_target_agent_token_id")
  defaultTargetAgentToken   AgentToken? @relation("PipelineDefaultGateway", fields: [defaultTargetAgentTokenId], references: [id], onDelete: SetNull)
  /// Hybrid execution: inherit account/org plane, force managed, or force customer gateway for new runs.
  executionHost PipelineExecutionHost @default(inherit) @map("execution_host")
  /// Saved source Connection row (non-secret config + optional secrets on Connection).
  sourceConnectionId String? @map("source_connection_id")
  sourceConnection   Connection? @relation("PipelineSourceConnection", fields: [sourceConnectionId], references: [id], onDelete: SetNull)
  /// Saved destination Connection row.
  destinationConnectionId String? @map("destination_connection_id")
  destinationConnection   Connection? @relation("PipelineDestinationConnection", fields: [destinationConnectionId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, name, tool])
  @@index([userId])
  @@index([sourceConnectionId])
  @@index([destinationConnectionId])
  runs EltPipelineRun[]
  eltMonitors EltMonitor[]
}

enum RunStatus {
  pending
  running
  succeeded
  failed
  cancelled
}

/// Execution records reported by runners, CI, or the app — structured logs only (no raw warehouse credentials).
model EltPipelineRun {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipelineId    String
  pipeline      EltPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  /// Whether ingestion ran on the customer agent, managed eltPulse worker, or was reported via the control-plane API.
  ingestionExecutor RunIngestionExecutor @default(unspecified) @map("ingestion_executor")
  status        RunStatus @default(pending)
  environment   String    @default("default")
  correlationId String    @unique
  /// When set, only this named gateway (Bearer on `AgentToken`) may poll and PATCH this run; null = any gateway for this user.
  targetAgentTokenId String?    @map("target_agent_token_id")
  targetAgentToken   AgentToken? @relation(fields: [targetAgentTokenId], references: [id], onDelete: SetNull)
  triggeredBy   String?
  /// Slice / partition value for the executor (e.g. dlt `sys.argv[1]` / `partition_key`). Populated by API, monitors, or Run slices.
  partitionValue  String? @map("partition_value") @db.Text
  /// Warehouse column name for this slice when applicable (aligns with `backfill:partition:<column>:<value>`).
  partitionColumn String? @map("partition_column") @db.Text
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  /// JSON array: [{ "at": ISO string, "level": "info"|"warn"|"error", "message": string }]
  logEntries    Json      @default("[]")
  /// JSON { "summary": { rowsLoaded?, bytesLoaded?, progress?, currentPhase?, currentResource?, updatedAt? }, "samples": [...] } — live + historical telemetry (gateway / managed worker PATCH).
  telemetry     Json      @default("{}")
  /// Sanitized error text for UI — never store connection strings or API keys here.
  errorSummary  String?   @db.Text
  webhookSentAt DateTime?
  webhookStatus String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, startedAt(sort: Desc)])
  @@index([pipelineId, startedAt(sort: Desc)])
  @@index([userId, status])
  @@index([userId, environment])
  @@index([userId, status, targetAgentTokenId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                 PlanTier           @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}
