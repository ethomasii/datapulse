// eltPulse — minimal SaaS schema (Clerk + Stripe + Neon)
// Extend with workspaces, pipelines, and run history as the product grows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Neon migrations: set DIRECT_URL to a non-pooled connection and uncomment:
  // directUrl = env("DIRECT_URL")
}

enum PlanTier {
  free
  pro
  team
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
  incomplete_expired
  paused
}

/// Who runs pipeline ingestion for this account. Telemetry (runs, logs) is always stored in eltPulse either way.
enum ExecutionPlane {
  /// Customer-operated execution (optional self-hosted agent token, CI, or control-plane API reporting).
  customer_agent
  /// eltPulse-operated execution when managed compute is available (roadmap).
  datapulse_managed
}

/// How this run’s telemetry was produced / who executed ingestion. Distinct from `triggeredBy` (schedule, webhook, etc.).
enum RunIngestionExecutor {
  unspecified
  customer_agent
  datapulse_managed
  /// Logged-in app or session API (`/api/elt/runs`) reporting without the self-hosted agent.
  customer_control_plane
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  imageUrl  String?
  /// Optional HTTPS URL — POST when a pipeline run finishes (success or failure). No warehouse secrets in payload.
  runsWebhookUrl String? @db.Text
  /// Secret token for the incoming webhook trigger endpoint (POST /api/webhooks/trigger/:token).
  incomingWebhookToken String? @unique @db.Text
  /// Secret token for the self-hosted eltPulse agent (polls pending runs, reports back). Optional — omit for API-only or managed-only flows.
  agentToken String? @unique @db.Text
  /// Preferred execution plane; does not require `agentToken` when set to `customer_agent` (CI / app can still report runs).
  executionPlane ExecutionPlane @default(customer_agent) @map("execution_plane")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription?
  eltPipelines EltPipeline[]
  githubConnection GithubConnection?
  eltPipelineRuns EltPipelineRun[]
  connections Connection[]
}

/// Optional: per-customer GitHub OAuth (BYO org). Disabled when using managed repos under eltPulse’s org only.
model GithubConnection {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubUserId     String
  githubLogin      String
  accessTokenEnc   String   @db.Text
  scope            String?
  defaultRepoOwner String?
  defaultRepoName  String?
  defaultBranch    String?  @default("main")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

/// Named, reusable connection profile (source or destination). Referenced by pipelines by name.
model Connection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Human-readable label, e.g. "prod-postgres" or "bigquery-warehouse"
  name        String
  /// "source" | "destination"
  connectionType String
  /// Connector key, e.g. "postgres", "bigquery", "snowflake", "github"
  connector   String
  /// Non-secret config blob (schema, project_id, account, etc.).
  config      Json     @default("{}")
  /// AES-256-GCM ciphertext of JSON `Record<envKey, secretValue>` (catalog keys only). Optional: agent / future managed runners.
  connectionSecretsEnc String? @map("connection_secrets_enc") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

/// Generated ELT pipeline definitions stored in Neon. Execution is customer-operated (optional agent / API) or eltPulse-managed when enabled.
model EltPipeline {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  tool                String // "dlt" | "sling"
  enabled             Boolean  @default(true)
  sourceType          String
  destinationType     String
  description         String?
  groupName           String?
  sourceConfiguration Json     @default("{}")
  pipelineCode        String   @db.Text
  configYaml          String?  @db.Text
  /// eltPulse workspace manifest (scheduling, monitors, metadata). Stored as YAML text.
  workspaceYaml       String?  @map("workspace_yaml") @db.Text
  /// Optional: POST run events here for this pipeline only (overrides account default when set).
  runsWebhookUrl      String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, name, tool])
  @@index([userId])
  runs EltPipelineRun[]
}

enum RunStatus {
  pending
  running
  succeeded
  failed
  cancelled
}

/// Execution records reported by runners, CI, or the app — structured logs only (no raw warehouse credentials).
model EltPipelineRun {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipelineId    String
  pipeline      EltPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  /// Whether ingestion ran on the customer agent, managed eltPulse worker, or was reported via the control-plane API.
  ingestionExecutor RunIngestionExecutor @default(unspecified) @map("ingestion_executor")
  status        RunStatus @default(pending)
  environment   String    @default("default")
  correlationId String    @unique
  triggeredBy   String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  /// JSON array: [{ "at": ISO string, "level": "info"|"warn"|"error", "message": string }]
  logEntries    Json      @default("[]")
  /// Sanitized error text for UI — never store connection strings or API keys here.
  errorSummary  String?   @db.Text
  webhookSentAt DateTime?
  webhookStatus String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, startedAt(sort: Desc)])
  @@index([pipelineId, startedAt(sort: Desc)])
  @@index([userId, status])
  @@index([userId, environment])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                 PlanTier           @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}
