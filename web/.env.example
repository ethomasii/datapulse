# ============================================================
# DataPulse (web/) — copy to .env.local
# https://github.com/ethomasii/datapulse
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Neon Postgres or local Postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/datapulse"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_TEAM_MONTHLY_PRICE_ID=price_...

# Resend — https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@datapulse.dev
RESEND_FROM_NAME=DataPulse

# Anthropic — optional; for AI-assisted flows
ANTHROPIC_API_KEY=sk-ant-...
