# ============================================================
# eltPulse (web/) — copy to .env.local (Next.js loads .env.local automatically)
# Public / external: https://github.com/eltpulsehq/eltpulse
#
# Minimum to run the app with a database: set DATABASE_URL below (and Clerk keys).
# .env.local is gitignored — create it locally:  cp .env.example .env.local
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ServicePulse (sibling product) — base URL for in-app links and ?eltpulse_origin= handoffs. Defaults to https://servicepulse.dev when unset.
# NEXT_PUBLIC_SERVICEPULSE_URL=https://servicepulse.dev

# --- DATABASE_URL (required) — Postgres for Prisma (pipelines, monitors, users, etc.) ---
# Database — Postgres connection URI (required for Prisma / npm run db:*)
# Shape: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
#
# If you use Neon (recommended for this app): https://console.neon.tech → your project →
# "Connection details" → copy "Connection string" (URI). Use the pooled string for serverless/Vercel if offered.
#
# If you use Postgres on your machine: same shape. Example for Docker:
#   docker run --name eltpulse-pg -e POSTGRES_PASSWORD=password -e POSTGRES_DB=eltpulse -p 5432:5432 -d postgres:16
# Then DATABASE_URL below matches user postgres, password password, db eltpulse.
DATABASE_URL="postgresql://postgres:password@localhost:5432/eltpulse"
# Same as DATABASE_URL when not using a pooler (local Docker / single Postgres).
DIRECT_URL="postgresql://postgres:password@localhost:5432/eltpulse"

# Neon: set DATABASE_URL to the pooled URI (…-pooler… in the host) and DIRECT_URL to the direct URI
# (same user/db/password; host without “-pooler”). Both are shown in Neon → Connect.
# DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.region.aws.neon.tech/neondb?sslmode=require"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_TEAM_MONTHLY_PRICE_ID=price_...

# Resend — https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@eltpulse.dev
RESEND_FROM_NAME=eltPulse

# Anthropic — optional; for AI-assisted flows
ANTHROPIC_API_KEY=sk-ant-...

# Token encryption (connection secrets, OAuth tokens) — 32-byte key, base64-encoded
# ELTPULSE_TOKEN_ENCRYPTION_KEY=

# --- GitHub: managed repos (default product) ---
# eltPulse uses ONE GitHub App or machine user + your org (e.g. github.com/eltpulse-customers).
# Put installation ID / app credentials in server-only env (see code when commit automation lands).
# Customers authenticate only with eltPulse (Clerk), not with GitHub.

# --- Optional: let a customer connect THEIR GitHub (BYO) — off by default ---
# Set true only for experiments or enterprise “push to my org”.
CUSTOMER_GITHUB_OAUTH_ENABLED=false
# GitHub OAuth app (https://github.com/settings/developers) — callback:
# {NEXT_PUBLIC_APP_URL}/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
